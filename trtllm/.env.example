# TensorRT-LLM stack configuration for NVIDIA DGX Spark
# Official image from NVIDIA's Spark playbook:
# https://build.nvidia.com/spark/trt-llm/instructions

# Model selection
# Set this to a DGX Spark-curated model handle from NVIDIA's matrix:
# https://build.nvidia.com/spark/trt-llm/instructions
# Examples:
#   nvidia/Qwen3-30B-A3B-FP4
#   nvidia/Llama-3.3-70B-Instruct-FP4
#   nvidia/Phi-4-multimodal-instruct-FP4
MODEL_HANDLE=

# Hugging Face cache and auth
# HF_TOKEN can be left empty for public models, but gated repos will fail without it.
HF_TOKEN=
HF_HOME=/home/michael/.cache/huggingface

# API and runtime tuning
# Bind address for the OpenAI-compatible API.
# Use a specific LAN or Tailscale IP if you want to limit exposure to one interface.
# Use 0.0.0.0 if the endpoint should be reachable on all host interfaces.
TRTLLM_BIND_HOST=0.0.0.0
# OpenAI-compatible API port exposed on the host
TRTLLM_PORT=8355
# Passed to trtllm-serve --max_batch_size
TRTLLM_MAX_BATCH_SIZE=64
# Written into kv_cache_config.free_gpu_memory_fraction
TRTLLM_FREE_GPU_MEMORY_FRACTION=0.90
# Set to 1 if Spark hits memory pressure during parallel weight loading
TRT_LLM_DISABLE_LOAD_WEIGHTS_IN_PARALLEL=
# Extra raw arguments appended to trtllm-serve
TRTLLM_SERVER_ARGS=
