# TensorRT-LLM stack configuration
TRTLLM_IMAGE=nvcr.io/nvidia/tensorrt-llm/release:1.2.0rc6
TRTLLM_CONTAINER_NAME=stacksmith_trtllm

# Model selection
MODEL_HANDLE=nvidia/Qwen3-30B-A3B-FP4

# Hugging Face cache and auth
HF_TOKEN=
HF_HOME=/home/michael/.cache/huggingface

# API and runtime tuning
TRTLLM_PORT=8355
TRTLLM_MAX_BATCH_SIZE=64
TRTLLM_FREE_GPU_MEMORY_FRACTION=0.90
TRT_LLM_DISABLE_LOAD_WEIGHTS_IN_PARALLEL=
TRTLLM_SERVER_ARGS=
