# Open WebUI configuration
# Official Docker image docs:
# https://docs.openwebui.com/getting-started/quick-start/
OPEN_WEBUI_HOSTNAME=ai.example.com

# Local access in addition to Traefik
OPEN_WEBUI_PORT=3000

# OpenAI-compatible backend connection
# Set this to the network-reachable inference endpoint.
# Same-host example over LAN/Tailscale:
#   http://100.76.167.25:8355/v1
# Dual-host example:
#   http://llm-box.tailnet-name.ts.net:8355/v1
OPENAI_API_BASE_URL=

# Leave empty or set to "none" if your backend does not require authentication.
OPENAI_API_KEY=

# Open WebUI provider toggles
ENABLE_OPENAI_API=true
ENABLE_OLLAMA_API=false
