# LiteLLM frontend image
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable

# External hostname (Traefik, Tailscale-only)
LITELLM_HOSTNAME=llm.example.com

# Master key for clients talking to LiteLLM
# Must start with sk-
LITELLM_MASTER_KEY=sk-change-me

# Stable client-facing alias presented to clients
LITELLM_MODEL_ALIAS=primary-model

# Upstream model name exposed by vLLM
LITELLM_UPSTREAM_MODEL=primary-chat

# Internal Docker-network URL for vLLM
LITELLM_VLLM_API_BASE=http://vllm:8000
LITELLM_VLLM_API_KEY=placeholder

# Set to false for model families that do not support system messages cleanly
LITELLM_SUPPORTS_SYSTEM_MESSAGE=true

# Optional embeddings route
LITELLM_EMBED_ALIAS=embed-main
LITELLM_EMBED_UPSTREAM_MODEL=
LITELLM_EMBED_API_BASE=
LITELLM_EMBED_API_KEY=placeholder
