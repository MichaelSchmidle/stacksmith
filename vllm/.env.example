VLLM_PRELAUNCH_PIP_PACKAGES=

# Model selection
VLLM_MODEL=your-org/your-model
VLLM_SERVED_MODEL_NAME=primary-chat
VLLM_QUANTIZATION=

# Runtime tuning
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_MAX_MODEL_LEN=32768
VLLM_HOST_PORT=8000
VLLM_EXTRA_ARGS=

# Optional access control for direct localhost testing only
VLLM_API_KEY=

# Optional Hugging Face token for higher rate limits / gated models
HF_TOKEN=
