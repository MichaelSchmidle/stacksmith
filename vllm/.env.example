# vLLM container image
# Current Spark-friendly nightly works with a pandas hotfix applied at container start.
VLLM_IMAGE=vllm/vllm-openai:cu130-nightly
VLLM_PRELAUNCH_PIP_PACKAGES=pandas

# Model selection
VLLM_MODEL=nvidia/Gemma-4-31B-IT-NVFP4
VLLM_SERVED_MODEL_NAME=gemma31-main
VLLM_QUANTIZATION=modelopt

# Runtime tuning
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_MAX_MODEL_LEN=8192
VLLM_HOST_PORT=8000
VLLM_EXTRA_ARGS=

# Optional access control for direct localhost testing only
VLLM_API_KEY=

# Optional Hugging Face token for higher rate limits / gated models
HF_TOKEN=
