STACKSMITH_PRELAUNCH_PIP_PACKAGES=

# Model selection
STACKSMITH_MODEL=your-org/your-model
STACKSMITH_SERVED_MODEL_NAME=primary-chat
STACKSMITH_QUANTIZATION=

# Runtime tuning
